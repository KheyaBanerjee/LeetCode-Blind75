# Problem link: https://leetcode.com/problems/product-of-array-except-self/description/
# Difficulty: Medium

# Problem statement:
# Given an integer array nums, return an array answer such that answer[i] is equal to the product of all the elements of nums except nums[i]. 
# The product of any prefix or suffix of nums is guaranteed to fit in a 32-bit integer.
# You must write an algorithm that runs in O(n) time and without using the division operation.
# Follow up: Can you solve the problem in O(1) extra space complexity? (The output array does not count as extra space for space complexity analysis.)

# Solution: For solution 1, time complexity O(N) and space complexity O(N)
#           For solution 2, time complexity O(N) and space complexity O(1)

# Two different prefix and postfix array
class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        n = len(nums)
        prefix, postfix, res = [1]*n, [1]*n, [1]*n
        for i in range(1, n):
            prefix[i] = prefix[i-1] * nums[i-1]
        for i in range((n-2), -1, -1):
            postfix[i] = postfix[i+1] * nums[i+1]
        for i in range(n):
            res[i] = prefix[i] * postfix[i]        
        return res


# One array includes both prefix and postfix
class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        n = len(nums)
        res = [1]*n
        prefix, postfix = 1, 1
        for i in range(n):
            res[i] = prefix
            prefix = prefix * nums[i]
        for i in range(n-1, -1, -1):
            res[i] = res[i] * postfix
            postfix = postfix * nums[i]
        return res
